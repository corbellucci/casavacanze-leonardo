# ==========================================
#  Casa Vacanze Leonardo - Variabili ambiente
#  Copia questo file in ".env" e compila i valori.
#  NON committare mai il file .env reale.
# ==========================================

# --- Server ---
PORT=3000
NODE_ENV=development
SESSION_SECRET=cambia_questo_valore_segreto

# --- Database ---
# In sviluppo: percorso file SQLite. In produzione (Render): stringa PostgreSQL.
DATABASE_URL=./src/db/local.sqlite

# --- Credenziali admin (usate dal seed per creare l'utente) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CasaLeonardo2026!

# --- PayPal (Sandbox per sviluppo, Live per produzione) ---
PAYPAL_CLIENT_ID=your_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret
PAYPAL_MODE=sandbox

# --- Email (Gmail SMTP del proprietario) ---
EMAIL_USER=proprietario@gmail.com
EMAIL_PASS=app_password_gmail
EMAIL_TO=info@casavacanzeleonardo.it

# --- URL pubblico (per link nelle email / webhook PayPal) ---
BASE_URL=http://localhost:3000
